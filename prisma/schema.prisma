generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String             @id @default(uuid())
  email                  String             @unique
  username               String             @unique
  passwordHash           String             @map("password_hash")
  avatarUrl              String?            @map("avatar_url")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")
  role                   String             @default("user") @map("role")
  preferences            Json               @default("{}")
  aiConfig               Json               @default("{}") @map("ai_config")
  emailConfig            Json               @default("{}") @map("email_config")
  passwordResetToken     String?            @map("password_reset_token")
  passwordResetExpiresAt DateTime?          @map("password_reset_expires_at")
  passwordResetCount     Int                @default(0) @map("password_reset_count")
  apiKeys                ApiKey[]
  categories             Category[]
  feeds                  Feed[]
  notifications          Notification[]
  readingHistory         ReadingHistory[]
  readingSessions        ReadingSession[]
  reportSchedules        ReportSchedule[]
  reports                Report[]
  searchHistory          SearchHistory[]
  subscriptionRules      SubscriptionRule[]
  userPreference         UserPreference?

  @@map("users")
}

model Category {
  id          String     @id @default(uuid())
  userId      String     @map("user_id")
  name        String
  description String?
  color       String?
  icon        String?
  parentId    String?    @map("parent_id")
  sortOrder   Int        @default(0) @map("sort_order")
  createdAt   DateTime   @default(now()) @map("created_at")
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  feeds       Feed[]

  @@unique([userId, name])
  @@index([userId])
  @@index([parentId])
  @@map("categories")
}

model Feed {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  categoryId    String?   @map("category_id")
  title         String
  description   String?
  feedUrl       String    @map("feed_url")
  siteUrl       String?   @map("site_url")
  iconUrl       String?   @map("icon_url")
  faviconUrl    String?   @map("favicon_url")
  lastFetchedAt DateTime? @map("last_fetched_at")
  lastSuccessAt DateTime? @map("last_success_at")
  nextFetchAt   DateTime? @map("next_fetch_at")
  fetchInterval Int       @default(3600) @map("fetch_interval")
  etag          String?
  lastModified  String?   @map("last_modified")
  errorCount    Int       @default(0) @map("error_count")
  lastError     String?   @map("last_error")
  isActive      Boolean   @default(true) @map("is_active")
  totalEntries  Int       @default(0) @map("total_entries")
  unreadCount   Int       @default(0) @map("unread_count")
  priority      Int       @default(5)
  tags          String[]  @default([])
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  entries       Entry[]
  category      Category? @relation(fields: [categoryId], references: [id])
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, feedUrl])
  @@index([userId])
  @@index([categoryId])
  @@index([lastFetchedAt])
  @@index([nextFetchAt])
  @@index([userId, isActive])
  @@index([userId, priority])
  @@map("feeds")
}

model Entry {
  id                 String             @id @default(uuid())
  feedId             String             @map("feed_id")
  title              String
  url                String
  content            String?
  summary            String?
  excerpt            String?
  author             String?
  authorUrl          String?            @map("author_url")
  publishedAt        DateTime?          @map("published_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  contentHash        String             @unique @map("content_hash")
  isRead             Boolean            @default(false) @map("is_read")
  isStarred          Boolean            @default(false) @map("is_starred")
  isArchived         Boolean            @default(false) @map("is_archived")
  readAt             DateTime?          @map("read_at")
  aiSummary          String?            @map("ai_summary")
  aiKeywords         String[]           @default([]) @map("ai_keywords")
  aiSentiment        String?            @map("ai_sentiment")
  aiCategory         String?            @map("ai_category")
  aiImportanceScore  Float              @default(0) @map("ai_importance_score")
  titleEmbedding     Bytes?             @map("title_embedding")
  contentEmbedding   Bytes?             @map("content_embedding")
  tags               String[]           @default([])
  hasMedia           Boolean            @default(false) @map("has_media")
  mainImageUrl       String?            @map("main_image_url")
  readingTime        Int?               @map("reading_time")
  aiOneLineSummary   String?            @map("ai_one_line_summary")
  aiMainPoints       Json?              @map("ai_main_points")
  aiKeyQuotes        Json?              @map("ai_key_quotes")
  aiScoreDimensions  Json?              @map("ai_score_dimensions")
  aiAnalysisModel    String?            @map("ai_analysis_model")
  aiProcessingTime   Int?               @map("ai_processing_time")
  aiReflectionRounds Int                @default(0) @map("ai_reflection_rounds")
  aiAnalyzedAt       DateTime?          @map("ai_analyzed_at")
  contentLength      Int?               @map("content_length")
  wordCount          Int?               @map("word_count")
  isOpenSource       Boolean?           @map("is_open_source")
  openSourceRepo     String?            @map("open_source_repo")
  openSourceLicense  String?            @map("open_source_license")
  openSourceStars    Int?               @map("open_source_stars")
  openSourceLanguage String?            @map("open_source_language")
  aiPrelimIgnore     Boolean?           @map("ai_prelim_ignore")
  aiPrelimReason     String?            @map("ai_prelim_reason")
  aiPrelimValue      Int?               @map("ai_prelim_value")
  aiPrelimSummary    String?            @map("ai_prelim_summary")
  aiPrelimLanguage   String?            @map("ai_prelim_language")
  aiPrelimStatus     String?            @map("ai_prelim_status")
  aiPrelimAnalyzedAt DateTime?          @map("ai_prelim_analyzed_at")
  aiPrelimModel      String?            @map("ai_prelim_model")
  aiAnalysisQueue    AIAnalysisQueue[]
  feedbacks          AnalysisFeedback[]
  sourceRelations    ArticleRelation[]  @relation("SourceRelations")
  targetRelations    ArticleRelation[]  @relation("TargetRelations")
  feed               Feed               @relation(fields: [feedId], references: [id], onDelete: Cascade)
  readingHistory     ReadingHistory[]
  readingSessions    ReadingSession[]
  reportEntries      ReportEntry[]

  @@index([feedId])
  @@index([publishedAt])
  @@index([isRead])
  @@index([isStarred])
  @@index([contentHash])
  @@index([feedId, publishedAt(sort: Desc)])
  @@index([feedId, isRead, publishedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([aiImportanceScore(sort: Desc)])
  @@index([aiCategory])
  @@index([isArchived, createdAt(sort: Desc)])
  @@index([isStarred, createdAt(sort: Desc)])
  @@index([aiPrelimStatus, aiPrelimValue(sort: Desc)])
  @@index([aiPrelimAnalyzedAt])
  @@map("entries")
}

model ReadingHistory {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  entryId        String    @map("entry_id")
  readProgress   Int       @default(0) @map("read_progress")
  scrollPosition Int       @default(0) @map("scroll_position")
  readingTime    Int       @default(0) @map("reading_time")
  firstOpenedAt  DateTime  @default(now()) @map("first_opened_at")
  lastOpenedAt   DateTime  @default(now()) @map("last_opened_at")
  completedAt    DateTime? @map("completed_at")
  source         String
  entry          Entry     @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entryId])
  @@index([userId])
  @@index([entryId])
  @@index([lastOpenedAt])
  @@map("reading_history")
}

model SearchHistory {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  query          String
  filters        Json?
  resultsCount   Int?     @map("results_count")
  clickedEntryId String?  @map("clicked_entry_id")
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("search_history")
}

model AIAnalysisQueue {
  id               String    @id @default(uuid())
  entryId          String    @map("entry_id")
  analysisType     String    @map("analysis_type")
  priority         Int       @default(5)
  status           String    @default("pending")
  provider         String?
  model            String?
  promptTokens     Int?      @map("prompt_tokens")
  completionTokens Int?      @map("completion_tokens")
  totalTokens      Int?      @map("total_tokens")
  cost             Decimal?  @db.Decimal(10, 6)
  errorMessage     String?   @map("error_message")
  retryCount       Int       @default(0) @map("retry_count")
  maxRetries       Int       @default(3) @map("max_retries")
  createdAt        DateTime  @default(now()) @map("created_at")
  startedAt        DateTime? @map("started_at")
  completedAt      DateTime? @map("completed_at")
  nextRetryAt      DateTime? @map("next_retry_at")
  entry            Entry     @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@index([status])
  @@index([nextRetryAt])
  @@index([status, priority(sort: Desc), createdAt])
  @@index([status, nextRetryAt])
  @@map("ai_analysis_queue")
}

model Report {
  id           String        @id @default(uuid())
  userId       String        @map("user_id")
  reportType   String        @map("report_type")
  reportDate   DateTime      @map("report_date") @db.Date
  status       String        @default("pending")
  progress     Int           @default(0) @map("progress")
  currentStep  String?       @map("current_step")
  errorMessage String?       @map("error_message")
  steps        Json?         @map("steps")
  title        String
  summary      String?
  highlights   String[]      @default([])
  topics       Json?
  totalEntries Int           @default(0) @map("total_entries")
  totalFeeds   Int           @default(0) @map("total_feeds")
  format       String        @default("markdown")
  content      String?
  aiGenerated  Boolean       @default(false) @map("ai_generated")
  aiModel      String?       @map("ai_model")
  isPublic     Boolean       @default(false) @map("is_public")
  shareToken   String?       @unique @map("share_token")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  entries      ReportEntry[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reportType, reportDate])
  @@index([userId])
  @@index([reportType, reportDate])
  @@index([shareToken])
  @@map("reports")
}

model ReportEntry {
  id        String   @id @default(uuid())
  reportId  String   @map("report_id")
  entryId   String   @map("entry_id")
  section   String
  rank      Int      @default(0)
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, entryId])
  @@index([reportId])
  @@map("report_entries")
}

model ReportSchedule {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  name              String
  firstRunAt        DateTime  @map("first_run_at")
  frequency         String
  nextRunAt         DateTime? @map("next_run_at")
  lastRunAt         DateTime? @map("last_run_at")
  dateRange         String    @map("date_range")
  customDays        Int?      @map("custom_days")
  includeStats      Boolean   @default(true) @map("include_stats")
  includeHighlights Boolean   @default(true) @map("include_highlights")
  includeAiSummary  Boolean   @default(true) @map("include_ai_summary")
  recipientEmail    String    @map("recipient_email")
  emailSubject      String?   @map("email_subject")
  isEnabled         Boolean   @default(true) @map("is_enabled")
  runCount          Int       @default(0) @map("run_count")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isEnabled])
  @@index([nextRunAt])
  @@map("report_schedules")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String
  title     String
  content   String?
  data      Json?
  isRead    Boolean   @default(false) @map("is_read")
  createdAt DateTime  @default(now()) @map("created_at")
  readAt    DateTime? @map("read_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model SubscriptionRule {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  name          String
  isEnabled     Boolean   @default(true) @map("is_enabled")
  conditions    Json
  actions       Json
  matchedCount  Int       @default(0) @map("matched_count")
  lastMatchedAt DateTime? @map("last_matched_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isEnabled])
  @@map("subscription_rules")
}

model ApiKey {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  name       String
  keyHash    String    @unique @map("key_hash")
  keyPrefix  String    @map("key_prefix")
  scopes     String[]  @default(["read", "write"])
  isActive   Boolean   @default(true) @map("is_active")
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

model ReadingSession {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  entryId           String    @map("entry_id")
  startedAt         DateTime  @default(now()) @map("started_at")
  endedAt           DateTime? @map("ended_at")
  dwellTime         Int       @default(0) @map("dwell_time")
  scrollDepth       Float     @default(0) @map("scroll_depth")
  isCompleted       Boolean   @default(false) @map("is_completed")
  isStarred         Boolean   @default(false) @map("is_starred")
  rating            Int?      @map("rating")
  attentionSegments Json?     @map("attention_segments")
  createdAt         DateTime  @default(now()) @map("created_at")
  entry             Entry     @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entryId, startedAt])
  @@index([userId, createdAt])
  @@index([entryId])
  @@map("reading_sessions")
}

model UserPreference {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  topicWeights    Json     @default("{}") @map("topic_weights")
  preferredDepth  String?  @map("preferred_depth")
  preferredLength String?  @map("preferred_length")
  excludedTags    String[] @default([]) @map("excluded_tags")
  totalReadTime   Int      @default(0) @map("total_read_time")
  totalEntries    Int      @default(0) @map("total_entries")
  avgCompletion   Float    @default(0) @map("avg_completion")
  avgDwellTime    Int      @default(0) @map("avg_dwell_time")
  diversityScore  Float    @default(0) @map("diversity_score")
  updatedAt       DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_preferences")
}

model ArticleRelation {
  id           String   @id @default(uuid())
  sourceId     String   @map("source_id")
  targetId     String   @map("target_id")
  relationType String   @map("relation_type")
  strength     Float    @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  sourceEntry  Entry    @relation("SourceRelations", fields: [sourceId], references: [id], onDelete: Cascade)
  targetEntry  Entry    @relation("TargetRelations", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, relationType])
  @@index([sourceId, relationType])
  @@index([targetId, relationType])
  @@index([strength])
  @@map("article_relations")
}

model AnalysisFeedback {
  id             String    @id @default(uuid())
  entryId        String    @map("entry_id")
  userId         String    @map("user_id")
  summaryIssue   String?   @map("summary_issue")
  tagSuggestions String[]  @default([]) @map("tag_suggestions")
  rating         Int?      @map("rating")
  isHelpful      Boolean?  @map("is_helpful")
  comments       String?   @map("comments")
  isApplied      Boolean   @default(false) @map("is_applied")
  appliedAt      DateTime? @map("applied_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  entry          Entry     @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, userId])
  @@index([entryId])
  @@index([userId])
  @@index([isApplied])
  @@map("analysis_feedback")
}

model SystemLog {
  id         String   @id @default(uuid())
  level      String
  category   String
  message    String
  details    Json?
  userId     String?  @map("user_id")
  requestId  String?  @map("request_id")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  stackTrace String?  @map("stack_trace")
  errorCode  String?  @map("error_code")
  duration   Int?
  memory     Int?
  source     String?
  tags       String[] @default([])
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([level])
  @@index([category])
  @@index([userId])
  @@index([createdAt])
  @@index([level, category])
  @@index([level, createdAt])
  @@map("system_logs")
}

model SystemSettings {
  id                 String    @id @default("system")
  isInitialized      Boolean   @default(false) @map("is_initialized")
  initializedAt      DateTime? @map("initialized_at")
  allowRegistration  Boolean   @default(true) @map("allow_registration")
  defaultUserRole    String    @default("user") @map("default_user_role")
  systemName         String    @default("RSS-Post") @map("system_name")
  systemLogo         String?   @map("system_logo")
  systemDescription  String?   @map("system_description")
  maintenanceMode    Boolean   @default(false) @map("maintenance_mode")
  maintenanceMessage String?   @map("maintenance_message")
  // 代理配置
  proxyEnabled       Boolean   @default(false) @map("proxy_enabled")
  proxyHost          String?   @map("proxy_host")
  proxyPort          Int?      @map("proxy_port")
  proxyType          String    @default("http") @map("proxy_type") // http, socks5, socks4
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("system_settings")
}
